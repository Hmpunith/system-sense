# System-Sense Environment Variables
# ──────────────────────────────────

# Your Gemini API key (get one at https://aistudio.google.com/)
# For this demo app, the key is entered in the browser UI directly.
# This file is for reference only.
GEMINI_API_KEY=your_api_key_here

# Port for Cloud Run (default: 8080)
PORT=8080
